# Mashgate API base URL. https://api.mashgate.uz for prod,
# http://localhost:9661 for local dev. MASHGATE_API_URL is accepted too.
MASHGATE_BASE_URL=https://api.mashgate.uz

# Environment-scoped API key: mg_test_... (sandbox) or mg_live_... (production).
MASHGATE_API_KEY=mg_test_...

# Signing secret for your webhook endpoint (from the Mashgate console).
# Only needed by the webhook receiver: `npm run webhook`.
MASHGATE_WEBHOOK_SECRET=whsec_...
